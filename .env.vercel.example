# Vercel backend environment
NODE_ENV=production

# Frontend origin
CLIENT_URL=https://nest-well.netlify.app
CLIENT_URLS=https://nest-well.netlify.app,http://localhost:5173

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/realestate?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# AI service
AI_SERVICE_URL=https://your-ai-service-domain
AI_SERVICE_INTERNAL_KEY=replace-with-the-same-shared-secret-as-the-ai-service

# Email
EMAIL_FROM=no-reply@yourapp.com
SMTP_HOST=xxx
SMTP_PORT=587
SMTP_USER=xxx
SMTP_PASSWORD=xxx

# Geocoding
NOMINATIM_USER_AGENT=RealEstatePlatform/1.0 (contact@yourapp.com)

