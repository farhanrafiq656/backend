# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/realestate

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# AI Service (internal)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_KEY=replace-with-a-shared-secret

# Email
EMAIL_FROM=no-reply@yourapp.com
SMTP_HOST=xxx
SMTP_PORT=587
SMTP_USER=xxx
SMTP_PASSWORD=xxx

# Geocoding
NOMINATIM_USER_AGENT=RealEstatePlatform/1.0 (contact@yourapp.com)
