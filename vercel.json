{
  "version": 2,
  "builds": [
    { "src": "api/[...path].js", "use": "@vercel/node" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://nest-well.netlify.app" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,PATCH,DELETE,OPTIONS" },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Internal-Api-Key"
        }
      ]
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/[...path].js" }
  ]
}
